{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-freshness",
      "urls": ["/api/transactions/recent", "/api/wallet/current"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "5m",
        "strategy": "freshness"
      }
    },
    {
      "name": "api-performance",
      "urls": ["/api/portfolio/summary", "/api/notifications/unread-count"],
      "cacheConfig": {
        "maxSize": 10,
        "maxAge": "10m",
        "strategy": "performance"
      }
    }
  ]
}
