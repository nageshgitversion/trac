# ════════════════════════════════════════════════════════════════════════════════
# INVESTRAC - Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment
# DO NOT commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────────
# Spring Boot & Application Settings
# ─────────────────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SPRING_APPLICATION_NAME=investrac
JAVA_OPTS=-Xmx512m -Xms256m

# ─────────────────────────────────────────────────────────────────────────────────
# Database Configuration (MySQL)
# ─────────────────────────────────────────────────────────────────────────────────
# Default: Docker MySQL container (started by docker-compose up -d).
#   - docker-compose.yml sets DB_HOST=mysql for all services automatically.
#   - No local MySQL installation required — data is stored in a Docker volume.
#   - DB_HOST below is only used when running services outside Docker (e.g. java -jar).
#
# Optional: Local MySQL instead of Docker MySQL.
#   - Use the override: docker-compose -f docker-compose.yml -f docker-compose.local-mysql.yml up -d
#   - See README.md "Local MySQL Setup" section for details.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=investrac
DB_USER=root
DB_PASSWORD=root
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_POOL_SIZE=20
DB_MAX_IDLE_TIME=900000

# ─────────────────────────────────────────────────────────────────────────────────
# Service Discovery - Eureka
# ─────────────────────────────────────────────────────────────────────────────────
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_USER=eureka-admin
EUREKA_PASSWORD=eureka-secret-2024
EUREKA_INSTANCE_PREFER_IP_ADDRESS=false

# ─────────────────────────────────────────────────────────────────────────────────
# Config Server
# ─────────────────────────────────────────────────────────────────────────────────
CONFIG_SERVER_PORT=8888
CONFIG_SERVER_USER=config-admin
CONFIG_SERVER_PASSWORD=config-secret
CONFIG_REPO_URI=https://github.com/your-org/investrac-config
CONFIG_REPO_BRANCH=main
CONFIG_REPO_SEARCH_PATHS={application}
CONFIG_REPO_CLONE_ON_START=true
CONFIG_REPO_TIMEOUT=10
CONFIG_REPO_FORCE_PULL=true
CONFIG_REPO_USERNAME=your-github-username
CONFIG_REPO_PASSWORD=your-github-token

# ─────────────────────────────────────────────────────────────────────────────────
# Encryption Keys
# ─────────────────────────────────────────────────────────────────────────────────
ENCRYPT_KEY=investrac-encrypt-key-change-in-prod
# For production, use: openssl rand -base64 32

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Optional: Embed keys directly (newlines as \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# BCrypt password encoding
BCRYPT_STRENGTH=10

# ─────────────────────────────────────────────────────────────────────────────────
# Message Queue - Kafka
# ─────────────────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=investrac-services
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_MAX_POLL_RECORDS=100
KAFKA_CONSUMER_SESSION_TIMEOUT_MS=30000
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_BATCH_SIZE=16384

# ─────────────────────────────────────────────────────────────────────────────────
# Caching - Redis
# ─────────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT_MS=2000
REDIS_MAX_RETRIES=3
REDIS_CACHE_TTL_MINUTES=30

# ─────────────────────────────────────────────────────────────────────────────────
# Service Ports
# ─────────────────────────────────────────────────────────────────────────────────
EUREKA_SERVER_PORT=8761
CONFIG_SERVER_PORT=8888
API_GATEWAY_PORT=8080
ADMIN_SERVER_PORT=9090
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
WALLET_SERVICE_PORT=8083
TRANSACTION_SERVICE_PORT=8084
ACCOUNT_SERVICE_PORT=8085
PORTFOLIO_SERVICE_PORT=8086
AI_SERVICE_PORT=8087
NOTIFICATION_SERVICE_PORT=8088

# ─────────────────────────────────────────────────────────────────────────────────
# Circuit Breaker - Resilience4j
# ─────────────────────────────────────────────────────────────────────────────────
RESILIENCE4J_CIRCUITBREAKER_FAILURE_RATE_THRESHOLD=50
RESILIENCE4J_CIRCUITBREAKER_WAIT_DURATION_MS=60000
RESILIENCE4J_CIRCUITBREAKER_PERMITTED_CALLS=5
RESILIENCE4J_RETRY_MAX_ATTEMPTS=3
RESILIENCE4J_RETRY_WAIT_DURATION_MS=1000

# ─────────────────────────────────────────────────────────────────────────────────
# Distributed Tracing - Zipkin
# ─────────────────────────────────────────────────────────────────────────────────
ZIPKIN_ENABLED=true
ZIPKIN_BASE_URL=http://localhost:9411
ZIPKIN_SAMPLER_PROBABILITY=0.1

# ─────────────────────────────────────────────────────────────────────────────────
# Monitoring - Prometheus
# ─────────────────────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─────────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_LEVEL_INVESTRAC=INFO
LOG_LEVEL_SPRING_FRAMEWORK=WARN
LOG_LEVEL_SPRING_CLOUD=DEBUG
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %msg%n
LOG_FILE_PATH=logs/investrac.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30

# ─────────────────────────────────────────────────────────────────────────────────
# Portfolio Service - Price Data APIs
# ─────────────────────────────────────────────────────────────────────────────────
# Mutual Fund API
MF_API_BASE_URL=https://api.mfapi.in/mf
MF_API_KEY=
MF_API_TIMEOUT_MS=10000

# Yahoo Finance (alternative for stocks)
YAHOO_FINANCE_API_KEY=
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
YAHOO_FINANCE_TIMEOUT_MS=10000

# Stock price sync schedule (cron format)
PORTFOLIO_SYNC_SCHEDULE=0 0 20 * * MON-FRI

# ─────────────────────────────────────────────────────────────────────────────────
# AI Service - Claude API (Anthropic)
# ─────────────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_API_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.7
CLAUDE_API_TIMEOUT_MS=30000

# Insight generation schedule
AI_INSIGHT_SCHEDULE=0 0 6 * * *

# ─────────────────────────────────────────────────────────────────────────────────
# Notification Service - Email (SMTP)
# ─────────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_ADDRESS=noreply@investrac.com
SMTP_FROM_NAME=INVESTRAC
SMTP_AUTH_ENABLED=true
SMTP_STARTTLS_ENABLED=true
SMTP_STARTTLS_REQUIRED=true
SMTP_SOCKET_FACTORY_PORT=587
SMTP_SOCKET_FACTORY_CLASS=javax.net.ssl.SSLSocketFactory
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_TIMEOUT_MS=5000

# ─────────────────────────────────────────────────────────────────────────────────
# Notification Service - Firebase Cloud Messaging (FCM)
# ─────────────────────────────────────────────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY_ID=your-private-key-id
FCM_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FCM_CLIENT_ID=1234567890
FCM_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FCM_TOKEN_URI=https://oauth2.googleapis.com/token
FCM_API_TIMEOUT_MS=10000

# ─────────────────────────────────────────────────────────────────────────────────
# Notification Service - SMS (Twilio or similar)
# ─────────────────────────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-account-sid
SMS_AUTH_TOKEN=your-auth-token
SMS_FROM_NUMBER=+1234567890
SMS_API_TIMEOUT_MS=5000

# ─────────────────────────────────────────────────────────────────────────────────
# Flyway Database Migrations
# ─────────────────────────────────────────────────────────────────────────────────
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_OUT_OF_ORDER=false
FLYWAY_VALIDATE_ON_MIGRATE=true

# ─────────────────────────────────────────────────────────────────────────────────
# Admin Dashboard
# ─────────────────────────────────────────────────────────────────────────────────
ADMIN_SERVER_PORT=9090
ADMIN_SERVER_USER=admin
ADMIN_SERVER_PASSWORD=admin-secret

# ─────────────────────────────────────────────────────────────────────────────────
# Development-specific settings
# ─────────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

# API Documentation (SpringDoc OpenAPI)
SPRINGDOC_SWAGGER_UI_ENABLED=true
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

# ─────────────────────────────────────────────────────────────────────────────────
# Security - Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# ─────────────────────────────────────────────────────────────────────────────────
# OWASP & Security Headers
# ─────────────────────────────────────────────────────────────────────────────────
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'

# ─────────────────────────────────────────────────────────────────────────────────
# External Services - NiFi (optional, for data pipelines)
# ─────────────────────────────────────────────────────────────────────────────────
NIFI_ENABLED=false
NIFI_BASE_URL=http://localhost:8161/nifi-api
NIFI_USERNAME=admin
NIFI_PASSWORD=admin123

# ─────────────────────────────────────────────────────────────────────────────────
# Actuator & Health Checks
# ─────────────────────────────────────────────────────────────────────────────────
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus,env,refresh,configprops
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
MANAGEMENT_ENDPOINT_HEALTH_SHOW_COMPONENTS=when-authorized
MANAGEMENT_HEALTH_LIVENESSSTATE_ENABLED=true
MANAGEMENT_HEALTH_READINESSSTATE_ENABLED=true
