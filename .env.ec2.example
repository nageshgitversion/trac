# ════════════════════════════════════════════════════════════════════════════════
# INVESTRAC — AWS EC2 Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env on your EC2 instance and fill in real values.
# DO NOT commit .env to version control!
#
# Usage:
#   cp .env.ec2.example .env
#   # Edit .env with your EC2-specific values
#   docker-compose -f docker-compose.yml -f docker-compose.ec2.yml up -d
#
# All services use the MySQL Docker container defined in docker-compose.yml.
# No local MySQL installation is required.
# ════════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# AWS EC2 / Host Configuration
# ─────────────────────────────────────────────────────────────────────────────────
# Your EC2 instance's public IP address or public DNS hostname.
# Obtain from: AWS Console → EC2 → Instances → your instance → Public IPv4 address
# Example: EC2_HOST=54.123.45.67   OR   EC2_HOST=ec2-54-123-45-67.compute-1.amazonaws.com
EC2_HOST=<YOUR_EC2_PUBLIC_IP_OR_DNS>

# ─────────────────────────────────────────────────────────────────────────────────
# Database Configuration (MySQL Docker container — no local install needed)
# ─────────────────────────────────────────────────────────────────────────────────
# DB_HOST is set to "mysql" (the Docker service name) inside docker-compose.yml.
# These credentials control the MySQL Docker container and all service connections.
DB_PORT=3306
DB_NAME=investrac
DB_USER=investrac
DB_PASSWORD=<STRONG_DB_PASSWORD>

# ─────────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# ─────────────────────────────────────────────────────────────────────────────────
# Generate with: chmod +x scripts/generate-jwt-keys.sh && ./scripts/generate-jwt-keys.sh
JWT_PRIVATE_KEY=<BASE64_ENCODED_PRIVATE_KEY>
JWT_PUBLIC_KEY=<BASE64_ENCODED_PUBLIC_KEY>

# ─────────────────────────────────────────────────────────────────────────────────
# Caching — Redis
# ─────────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>

# ─────────────────────────────────────────────────────────────────────────────────
# AI Service — Claude API (Anthropic)
# ─────────────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-<YOUR_ANTHROPIC_API_KEY>

# ─────────────────────────────────────────────────────────────────────────────────
# Notification Service — Email (SMTP)
# ─────────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<YOUR_EMAIL>
SMTP_PASSWORD=<YOUR_APP_SPECIFIC_PASSWORD>

# ─────────────────────────────────────────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPT_KEY=<STRONG_ENCRYPT_KEY>
ENCRYPTION_KEY=<64_HEX_CHARS_FOR_USER_SERVICE>
